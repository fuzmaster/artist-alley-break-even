# Artist Alley Break-Even Calculator — Environment Variables
#
# Copy this file to .env.local for local overrides.
# Set these in your Vercel project settings for production.

# Plausible Analytics
# Create a free site at https://plausible.io, then set this to your domain.
# Example: VITE_PLAUSIBLE_DOMAIN=artistalley.jacobbritten.com
# Leave blank to disable analytics (safe for local dev).
VITE_PLAUSIBLE_DOMAIN=
